# Knight COI Manager phase-2 runtime settings

NODE_ENV=development
PORT=3030

# Basic Auth (optional, enabled by default for production)
BASIC_AUTH_ENABLED=true
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=KnightCOI2026!Secure

# Data paths
KNIGHT_COI_DATA_DIR=data
DEMO_STATE_PATH=data/demo/demo-store-state.json

# Postgres
DATABASE_URL=postgres://user:password@localhost:5432/knight_coi
DATABASE_SSL=false
KNIGHT_COI_PG_SCHEMA=public

# Provider ingestion / import paths
KNIGHT_COI_MAILBOX_SYNC_ENABLED=false
KNIGHT_COI_PROVIDER_IMPORT_DIR=data/imports/providers
KNIGHT_COI_APPLE_MAIL_EXPORT_DIR=data/imports/apple-mail
KNIGHT_COI_GMAIL_IMPORT_DIR=data/imports/gmail
KNIGHT_COI_EXCHANGE_IMPORT_DIR=data/imports/exchange
